# 到 https://aistudio.google.com/app/apikey 申请 Gemini API Key
GEMINI_API_KEY=

## 模型（默认统一使用 Gemini 3 Flash Preview）
GEMINI_MODEL=gemini-3-flash-preview
SUBTITLE_MODE=bilingual-zh
SUBTITLE_FORMAT=srt
SUBTITLE_TIMING=align
# 英语推荐 medium.en，多语言推荐 medium
# ALIGN_MODEL=medium.en

## 可选：网络代理（yt-dlp / requests 均可读取这些变量）
# 如无需代理，请留空
#HTTP_PROXY=
#HTTPS_PROXY=
#ALL_PROXY=

## 可选：仅给 yt-dlp 设置代理（优先级高于上面的通用代理）
#YT_DLP_PROXY=

# 可选：显式指定 ffmpeg / ffprobe 路径。
# 在 WSL + Windows FFmpeg 场景下尤其有用。
#FFMPEG_BIN=/usr/bin/ffmpeg
#FFPROBE_BIN=/usr/bin/ffprobe

# 可选：字幕分片时长与并发。
SEGMENT_SECONDS=1200
TRANSCRIBE_CONCURRENCY=4

# 可选：转录前先做人声分离，默认 vocals；如需关闭可改成 raw。
#TRANSCRIBE_AUDIO_MODE=vocals

# 可选：若在独立环境里运行 Demucs，可显式指定解释器路径。
#DEMUCS_PYTHON=/path/to/demucs-python
#DEMUCS_MODEL=htdemucs
#DEMUCS_DEVICE=cpu

# 说明：
# - CLI 会优先加载 ~/.config/ai-video-transcriber/.env。
# - 其次会读取项目目录下的 .env.local / .env。
# - 建议把真实密钥放在 ~/.config/ai-video-transcriber/.env，不要放进仓库目录。
